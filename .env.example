# Neo4j connection (the KG built by multiomics_biocypher_kg).
# NEO4J_USERNAME is canonical (matches Neo4j BKM — Aura's "Connect"
# credential file). NEO4J_USER is also accepted as a back-compat alias.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=
NEO4J_PASSWORD=
# Optional, defaults to "neo4j":
# NEO4J_DATABASE=neo4j

# Optional: path to KG builder repo for richer schema metadata
# KG_REPO_PATH=/home/osnat/github/multiomics_biocypher_kg
