# Neo4j connection (the KG built by multiomics_biocypher_kg)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=
NEO4J_PASSWORD=

# LLM configuration (uses langchain init_chat_model)
MODEL=claude-sonnet-4-5-20250929
MODEL_PROVIDER=anthropic
MODEL_TEMPERATURE=0

# API keys (set whichever provider you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: path to KG builder repo for richer schema metadata
# KG_REPO_PATH=/home/osnat/github/multiomics_biocypher_kg
